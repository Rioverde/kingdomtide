<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Gongeons — world {{.Seed}}</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <header>
    <form id="seedForm">
      <label>seed <input id="seed" type="number" name="seed" value="{{.Seed}}" step="1"></label>
      <button type="submit">regenerate</button>
    </form>
    <div class="zoom">
      <label>zoom <input id="zoom" type="range" min="10" max="200" step="5" value="40"></label>
      <span id="zoomLabel">40%</span>
    </div>
    <div class="coords" id="coords">0, 0</div>
  </header>
  <main id="viewport" class="viewport"></main>
  <script src="/static/app.js"></script>
</body>
</html>
